CREATE TABLE IF NOT EXISTS subagent_runs (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    status TEXT NOT NULL DEFAULT 'RUNNING',
    model TEXT,
    source_chat_id TEXT,
    source_channel TEXT,
    start_time TEXT NOT NULL,
    end_time TEXT,
    duration_ms INTEGER,
    result TEXT,
    last_response TEXT,
    error TEXT,
    inject_into TEXT
);

CREATE INDEX IF NOT EXISTS idx_subagent_runs_start ON subagent_runs(start_time DESC);
CREATE INDEX IF NOT EXISTS idx_subagent_runs_source ON subagent_runs(source_chat_id);

insertRun:
INSERT INTO subagent_runs (id, name, status, model, source_chat_id, source_channel, start_time, inject_into)
VALUES (?, ?, 'RUNNING', ?, ?, ?, ?, ?);

updateCompleted:
UPDATE subagent_runs
SET status = 'COMPLETED', end_time = ?, duration_ms = ?, last_response = ?, result = ?
WHERE id = ?;

updateFailed:
UPDATE subagent_runs
SET status = 'FAILED', end_time = ?, duration_ms = ?, error = ?
WHERE id = ?;

updateCancelled:
UPDATE subagent_runs
SET status = 'CANCELLED', end_time = ?, duration_ms = ?
WHERE id = ?;

getRunById:
SELECT * FROM subagent_runs WHERE id = ? AND source_chat_id = ?;

getRunByIdGlobal:
SELECT * FROM subagent_runs WHERE id = ?;

listRecent:
SELECT * FROM subagent_runs
WHERE source_chat_id = ?
ORDER BY start_time DESC
LIMIT ?;

countByStatus:
SELECT COUNT(*) FROM subagent_runs WHERE status = ?;

markStaleRunsFailed:
UPDATE subagent_runs
SET status = 'FAILED', end_time = start_time, duration_ms = 0, error = 'EngineCrash'
WHERE status = 'RUNNING';

deleteOldRuns:
DELETE FROM subagent_runs
WHERE id NOT IN (
    SELECT id FROM subagent_runs ORDER BY start_time DESC LIMIT ?
);

listRecentByName:
SELECT * FROM subagent_runs
WHERE name = ?
ORDER BY start_time DESC
LIMIT ?;
