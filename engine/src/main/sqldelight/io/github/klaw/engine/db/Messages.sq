CREATE TABLE IF NOT EXISTS messages (
    id TEXT NOT NULL PRIMARY KEY,
    channel TEXT NOT NULL,
    chat_id TEXT NOT NULL,
    role TEXT NOT NULL,
    type TEXT NOT NULL,
    content TEXT NOT NULL,
    metadata TEXT,
    created_at TEXT NOT NULL,
    tokens INTEGER NOT NULL DEFAULT 0
);

CREATE INDEX IF NOT EXISTS idx_messages_chat_id ON messages (chat_id);

insertMessage:
INSERT OR REPLACE INTO messages (id, channel, chat_id, role, type, content, metadata, created_at, tokens)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getWindowMessages:
SELECT rowid AS row_id, id, channel, chat_id, role, type, content, metadata, created_at, tokens
FROM messages
WHERE chat_id = ? AND created_at >= ?
ORDER BY created_at DESC, rowid DESC;

getLastMessageId:
SELECT id FROM messages
WHERE chat_id = ?
ORDER BY created_at DESC
LIMIT 1;

deleteAllMessages:
DELETE FROM messages;

countMessages:
SELECT COUNT(*) FROM messages;

countByChatId:
SELECT COUNT(*) FROM messages WHERE chat_id = ?;

getMessagesByChatId:
SELECT * FROM messages
WHERE chat_id = ?
ORDER BY created_at ASC, rowid ASC;

lastInsertRowId:
SELECT last_insert_rowid();

getAllMessages:
SELECT rowid AS rowid, id, channel, chat_id, role, type, content, metadata, created_at, tokens
FROM messages
ORDER BY rowid ASC;

sumTokensInSegment:
SELECT COALESCE(SUM(tokens), 0) FROM messages WHERE chat_id = :chatId AND created_at >= :segmentStart;

updateTokensById:
UPDATE messages SET tokens = :tokens WHERE id = :id;

updateMetadataById:
UPDATE messages SET metadata = :metadata WHERE id = :id;

getMessagesAfterCoverage:
SELECT rowid AS row_id, id, channel, chat_id, role, type, content, metadata, created_at, tokens
FROM messages
WHERE chat_id = :chatId AND created_at > :coverageEnd AND created_at >= :segmentStart
ORDER BY created_at ASC, rowid ASC;

getAllMessagesInSegment:
SELECT rowid AS row_id, id, channel, chat_id, role, type, content, metadata, created_at, tokens
FROM messages
WHERE chat_id = :chatId AND created_at >= :segmentStart
ORDER BY created_at ASC, rowid ASC;

getWindowUncoveredMessages:
SELECT rowid AS row_id, id, channel, chat_id, role, type, content, metadata, created_at, tokens
FROM messages
WHERE chat_id = :chatId AND created_at > :coverageEnd AND created_at >= :segmentStart
ORDER BY created_at DESC, rowid DESC;

getMessagesByTimeRange:
SELECT rowid AS row_id, id, channel, chat_id, role, type, content, metadata, created_at, tokens
FROM messages
WHERE created_at >= :fromTime AND created_at < :toTime
  AND role IN ('user', 'assistant')
  AND type != 'tool_call'
ORDER BY created_at ASC, rowid ASC;

sumTokensByChatId:
SELECT COALESCE(SUM(tokens), 0) FROM messages WHERE chat_id = :chatId;

deleteMessagesByChatId:
DELETE FROM messages WHERE chat_id = :chatId;
